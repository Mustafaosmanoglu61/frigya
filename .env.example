APP_ENV=development
SESSION_SECRET=dev-local-change-this-secret

# Local SQLite path (optional; default webapp/tax.db)
DB_PATH=webapp/tax.db

# Initial admin user created on first startup.
# IMPORTANT: change the password before deploying anywhere public.
INITIAL_ADMIN_EMAIL=admin@example.local
INITIAL_ADMIN_PASSWORD=CHANGE_ME_BEFORE_DEPLOY

# Optional Google login (leave empty if not needed)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:8000/auth/google/callback

# Optional: absolute path to Midas CSV when seeding (webapp/seed_2026.py)
MIDAS_CSV_PATH=

# Optional: output Excel path for build_2025_usd.py
TAX_XLSX_PATH=

# Claude API key for webapp/claude_chat_client.py
ANTHROPIC_API_KEY=

# Massive Market Data — webapp Frigya AI analizinin piyasa (teknik/haber) verisi için.
# Boşsa /api/ai/frigya/sembol DB-only çalışır (pozisyon, FIFO, notlar, hedefler).
MASSIVE_API_KEY=
# Opsiyonel: base URL ve auth şeması (default: https://api.massive.com, bearer)
# MASSIVE_BASE_URL=https://api.massive.com
# MASSIVE_AUTH_MODE=bearer   # bearer | apikey | xapikey
